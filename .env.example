# SITAG Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development and fill in real values.
# NEVER commit .env to source control — it is listed in .gitignore.
#
# In Railway, set these via the service's "Variables" tab.
# PostgreSQL is accessed via Railway private networking:
#   Host: <service>.railway.internal   Port: 5432
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Railway private network example:
#   Host=postgres.railway.internal;Port=5432;Database=sitag;Username=postgres;Password=secret
# Local example:
#   Host=localhost;Port=5432;Database=sitag;Username=postgres;Password=secret
ConnectionStrings__Default=Host=localhost;Port=5432;Database=sitag;Username=postgres;Password=CHANGE_ME

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# Railway sets PORT automatically; ASPNETCORE_URLS can override the bind address.
# Leave commented out for Railway (PORT is used instead).
# ASPNETCORE_URLS=http://+:8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Issuer and Audience must match between backend and frontend token validation.
JWT__Issuer=https://sitag.app
JWT__Audience=sitag-api
# Minimum 32 characters, randomly generated.
JWT__SigningKey=CHANGE_ME_use_a_long_random_secret_here_32plus_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS__AllowedOrigins=http://localhost:3000,http://localhost:5173
